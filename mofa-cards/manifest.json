  "tools": [
    {
      "name": "mofa_cards",
      "description": "Generate AI-powered greeting cards and holiday cards as PNG images.",
      "input_schema": {
        "type": "object",
        "properties": {
          "cards": {
            "type": "array",
            "description": "Array of card objects",
            "items": {
              "type": "object",
              "properties": {
                "prompt": { "type": "string", "description": "Card content description" },
                "style": { "type": "string", "description": "Card variant" }
              },
              "required": ["prompt"]
            }
          },
          "style": { "type": "string", "description": "Style template name (default: cny-guochao)", "default": "cny-guochao" },
          "card_dir": { "type": "string", "description": "Output directory for card PNGs" },
          "aspect": { "type": "string", "description": "Aspect ratio" },
          "concurrency": { "type": "integer", "description": "Parallel generation limit (default: 5)" },
          "image_size": { "type": "string", "description": "Image size: 1K, 2K, 4K" }
        },
        "required": ["cards", "card_dir"]
      }
    }
  ]
}

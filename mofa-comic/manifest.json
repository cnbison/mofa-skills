  "tools": [
    {
      "name": "mofa_comic",
      "description": "Generate multi-panel comic strips with AI-generated art.",
      "input_schema": {
        "type": "object",
        "properties": {
          "panels": {
            "type": "array",
            "description": "Array of panel objects",
            "items": {
              "type": "object",
              "properties": {
                "prompt": { "type": "string", "description": "Panel content description" },
                "style": { "type": "string", "description": "Panel variant" }
              },
              "required": ["prompt"]
            }
          },
          "style": { "type": "string", "description": "Style template name (default: xkcd)", "default": "xkcd" },
          "out": { "type": "string", "description": "Output PNG file path" },
          "work_dir": { "type": "string", "description": "Working directory for panel PNGs" },
          "layout": { "type": "string", "description": "Layout: horizontal, vertical, grid", "default": "horizontal" },
          "concurrency": { "type": "integer", "description": "Parallel generation limit (default: 3)" },
          "gutter": { "type": "integer", "description": "Gap between panels in pixels (default: 20)" },
          "refine": { "type": "boolean", "description": "Refine panels with Qwen-Edit" }
        },
        "required": ["panels", "out"]
      }
    }
  ]
}

  "tools": [
    {
      "name": "mofa_video",
      "description": "Generate animated video cards with AI images and Veo animation.",
      "input_schema": {
        "type": "object",
        "properties": {
          "cards": {
            "type": "array",
            "description": "Array of video card objects",
            "items": {
              "type": "object",
              "properties": {
                "prompt": { "type": "string", "description": "Card content description" },
                "style": { "type": "string", "description": "Card variant" }
              },
              "required": ["prompt"]
            }
          },
          "style": { "type": "string", "description": "Image style name (default: video-card)", "default": "video-card" },
          "anim_style": { "type": "string", "description": "Animation style name (default: shuimo)", "default": "shuimo" },
          "card_dir": { "type": "string", "description": "Output directory for PNGs and MP4s" },
          "bgm": { "type": "string", "description": "Background music file path" },
          "aspect": { "type": "string", "description": "Aspect ratio (default: 9:16)", "default": "9:16" },
          "concurrency": { "type": "integer", "description": "Parallel generation limit (default: 3)" }
        },
        "required": ["cards", "card_dir"]
      }
    }
  ]

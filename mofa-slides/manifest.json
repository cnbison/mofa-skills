{
  "name": "mofa-slides",
  "version": "0.1.0",
  "timeout_secs": 1800,
  "binaries": {
    "darwin-aarch64": {
      "url": "https://github.com/mofa-org/mofa-skills/releases/download/v0.2.0/mofa-darwin-aarch64.tar.gz",
      "sha256": "c02525ab00c4b81c95b87afb9a2018c81ced5af8eab9b25840a0f351a5e452e5"
    },
    "darwin-x86_64": {
      "url": "https://github.com/mofa-org/mofa-skills/releases/download/v0.2.0/mofa-darwin-x86_64.tar.gz",
      "sha256": "18cbcc13722440f174943a629ebe67ed6e6aa529848984637aeeca8821d1155a"
    },
    "linux-x86_64": {
      "url": "https://github.com/mofa-org/mofa-skills/releases/download/v0.2.0/mofa-linux-x86_64.tar.gz",
      "sha256": "458c1da00cda7313b19abab9b80038e0b1423fa28e3ab241e2a07acc70d14048"
    }
  },
  "tools": [
    {
      "name": "mofa_slides",
      "description": "Generate AI presentation slides with full-bleed Gemini images. Supports multiple styles and editable PPTX mode.",
      "input_schema": {
        "type": "object",
        "properties": {
          "slides": {
            "type": "array",
            "description": "Array of slide objects",
            "items": {
              "type": "object",
              "properties": {
                "prompt": { "type": "string", "description": "Slide content description" },
                "style": { "type": "string", "description": "Slide variant: cover, normal, data, warm" },
                "auto_layout": { "type": "boolean", "description": "Enable editable text mode for this slide" },
                "source_image": { "type": "string", "description": "Existing image to use as-is" }
              },
              "required": ["prompt"]
            }
          },
          "style": { "type": "string", "description": "Style template name (default: nb-pro)", "default": "nb-pro" },
          "out": { "type": "string", "description": "Output PPTX file path" },
          "slide_dir": { "type": "string", "description": "Directory for intermediate PNGs (auto-created if omitted)" },
          "auto_layout": { "type": "boolean", "description": "Enable editable text mode for ALL slides" },
          "concurrency": { "type": "integer", "description": "Parallel generation limit (default: 5)" },
          "image_size": { "type": "string", "description": "Image size: 1K, 2K, 4K" },
          "refine": { "type": "boolean", "description": "Use Qwen-Edit for text cleanup" },
          "api": { "type": "string", "description": "API mode: rt (realtime, fast) or batch (50% cheaper, async)", "default": "rt", "enum": ["rt", "batch"] }
        },
        "required": ["slides", "out"]
      }
    }
  ]
}

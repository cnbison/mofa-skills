# Cloudflare Crawler API Configuration
# 快速开始指南：https://developers.cloudflare.com/browser-rendering/

# ============================================
# STEP 1: 获取 Account ID
# ============================================
# 1. 登录 https://dash.cloudflare.com
# 2. 在右侧边栏找到 "Account ID" (32位字符串)
# 3. 复制并粘贴到下方

CF_ACCOUNT_ID=your_account_id_here


# ============================================
# STEP 2: 创建 API Token
# ============================================
# 1. 登录 https://dash.cloudflare.com
# 2. 点击右上角头像 → "My Profile"
# 3. 选择 "API Tokens" 标签
# 4. 点击 "Create Token"
# 5. 选择 "Custom token" 模板
# 6. 配置权限：
#    - Token name: crawler-token
#    - Permissions: Account - Browser Rendering - Edit
#    - (可选) 限制IP范围以提高安全性
# 7. 点击 "Continue" → "Create Token"
# 8. ⚠️ 立即复制 token（只显示一次！）
# 9. 粘贴到下方

CF_API_TOKEN=your_api_token_here


# ============================================
# STEP 3: 验证配置
# ============================================
# 复制本文件为 .env：
#   cp .env.example .env
# 填入真实值后测试：
#   curl -X GET "https://api.cloudflare.com/client/v4/accounts/$CF_ACCOUNT_ID/browser-rendering" \
#     -H "Authorization: Bearer $CF_API_TOKEN"

# 返回 {"success": true} 表示配置成功！
